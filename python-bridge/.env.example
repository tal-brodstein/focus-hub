# Serial port of the Arduino.
# If omitted, the bridge auto-detects by scanning for known USB-serial chips
# (CH340, CP210x, FTDI, etc.).  Override when auto-detection picks the wrong port.
# Windows: COM3, COM4, …   Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0, …
SERIAL_PORT=COM3

# Path to the Firebase service account JSON key.
# Download from Firebase Console → Project Settings → Service Accounts
# → Generate new private key.
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
